# ─────────────────────────────────────────
#  PRISM Analytics — Environment Variables
#  Copy this file to .env and fill values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────

# ── LLM Providers (Dual Router) ──────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Router Config ────────────────────
# Primary model tried first
PRIMARY_LLM=gemini                        # gemini | groq
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-70b-versatile

# Rate limit thresholds (stay under free tier)
GEMINI_RPM_LIMIT=14                       # Real limit: 15 — buffer of 1
GROQ_RPM_LIMIT=28                         # Real limit: 30 — buffer of 2
GEMINI_DAILY_LIMIT=1400                   # Real limit: 1500 — buffer of 100
GROQ_DAILY_LIMIT=14000                    # Real limit: 14400 — buffer of 400

# Circuit breaker: errors before opening circuit
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=300              # seconds to wait before retry

# ── Vector DB (Qdrant) ───────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=prism_chunks

# ── Embeddings ───────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2         # Local HuggingFace, zero cost

# ── Chunking Strategy ────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── App Config ───────────────────────────
APP_ENV=development                       # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Instagram (yt-dlp cookie mode) ───────
# Export cookies from your browser using the EditThisCookie extension
# then point yt-dlp to the file path below
INSTAGRAM_COOKIES_PATH=./cookies/instagram.txt
